# --- Gemini ---
# Each user pastes their own Gemini key into the sidebar Settings panel in the
# UI. The server reads it from the X-Gemini-Key header on every request.
# GEMINI_API_KEY in this file is no longer used and is intentionally ignored.
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-1.5-flash

# --- GitHub (optional; required for private repos / higher rate limit) ---
GITHUB_TOKEN=

# --- Postgres ---
DATABASE_URL=postgresql://repoknow:repoknow@localhost:5433/repoknow

# --- App ---
SYNC_INTERVAL_HOURS=12
MAX_FILE_BYTES=400000
EMBED_BATCH_SIZE=64
TOP_K_CODE=10
TOP_K_SKILLS=5
MIN_RETRIEVAL_SCORE=0.30
