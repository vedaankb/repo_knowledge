    "content": "server/tests/test_api_heic.py :: test_convert_png_to_heic\ndef test_convert_png_to_heic(client: TestClient) -> None:\n    from helpers import png_bytes\n\n    payload = png_bytes(solid_raster(10, 10, 120, 80, 40))\n    response = client.post(\n        \"/convert\",\n        data={\"format\": \"heic\", \"max_mb\": \"1\"},\n        files={\"image\": (\"sample.png\", payload, \"image/png\")},\n    )\n    assert response.status_code == 200\n    assert response.headers[\"content-type\"].startswith(\"image/heic\")\n    assert response.content[4:8] == b\"ftyp\"",
