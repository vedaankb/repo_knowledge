    "language": "python",
    "content": "server/src/image_tool/formats.py :: parse_output_format\ndef parse_output_format(value: str | None) -> OutputFormat | None:\n    normalized = str(value or \"\").lower()\n    if normalized in {\"jpg\", \"jpeg\"}:\n        return OutputFormat(\"image/jpeg\", \"jpg\")\n    if normalized == \"png\":\n        return OutputFormat(\"image/png\", \"png\")\n    if normalized == \"heic\":\n        return OutputFormat(\"image/heic\", \"heic\")\n    if normalized == \"pdf\":\n        return OutputFormat(\"application/pdf\", \"pdf\")\n    if normalized == \"gif\":\n        return OutputFormat(\"image/gif\", \"gif\")\n    if normalized == \"webp\":\n        return OutputFormat(\"image/webp\", \"webp\")\n    if normalized in {\"tif\", \"tiff\"}:\n        return OutputFormat(\"image/tiff\", \"tiff\")\n    if normalized == \"bmp\":\n        return OutputFormat(\"image/bmp\", \"bmp\")\n    return None",
    "content_hash": "sha256:6f4336ff558cea8b0bbb88accb385e4a9e7c0287a647a52c9dd71a0c9cdbe7d9",
