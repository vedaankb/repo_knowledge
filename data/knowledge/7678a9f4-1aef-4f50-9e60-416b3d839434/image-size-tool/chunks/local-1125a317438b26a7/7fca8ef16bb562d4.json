    "kind": "function_definition",
    "language": "python",
    "content": "server/src/image_tool/exif/strip.py :: strip_jpeg_metadata\ndef strip_jpeg_metadata(data: bytes) -> bytes:\n    \"\"\"Return JPEG bytes without EXIF/ICC/comment APP segments.\"\"\"\n    if not data.startswith(b\"\\xFF\\xD8\"):\n        return data\n\n    output = bytearray(b\"\\xFF\\xD8\")\n    index = 2\n    while index < len(data):\n        if data[index] != 0xFF:\n            index += 1\n            continue\n        marker = data[index + 1]\n        if marker == 0xD9:\n            output.extend(data[index:])\n            return bytes(output)\n        if marker in (0xD8,):\n            index += 2\n            continue\n        if index + 4 > len(data):\n            break\n        length = struct.unpack_from(\">H\", data, index + 2)[0]\n        segment_end = index + 2 + length\n        if segment_end > len(data):\n            break\n        payload = data[index + 4 : segment_end]\n        if 0xE0 <= marker <= 0xEF and _is_metadata_segment(marker, payload):\n            index = segment_end\n            continue\n        output.extend(data[index:segment_end])\n        index = segment_end\n\n    return bytes(output)",
