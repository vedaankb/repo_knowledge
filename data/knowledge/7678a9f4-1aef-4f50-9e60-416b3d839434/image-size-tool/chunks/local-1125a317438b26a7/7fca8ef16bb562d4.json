    "content": "server/src/image_tool/exif/strip.py :: _is_metadata_segment\ndef _is_metadata_segment(marker: int, payload: bytes) -> bool:\n    if marker == 0xE1 and payload.startswith(b\"Exif\\x00\\x00\"):\n        return True\n    if marker == 0xE2 and payload.startswith(b\"ICC_PROFILE\"):\n        return True\n    if marker == 0xED and payload.startswith(b\"Photoshop\"):\n        return True\n    if marker == 0xFE:\n        return True\n    if marker == 0xE1 and payload.startswith(b\"http://ns.adobe.com\"):\n        return True\n    return False",
