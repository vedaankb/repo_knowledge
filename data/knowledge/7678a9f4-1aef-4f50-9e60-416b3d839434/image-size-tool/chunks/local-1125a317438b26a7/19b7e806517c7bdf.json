    "content": "server/src/image_tool/tiff/encode.py :: encode_tiff\ndef encode_tiff(\n    raster: Raster,\n    *,\n    compression: str = \"none\",\n    little_endian: bool = True,\n) -> bytes:\n    source = raster.to_rgb()\n    width = source.width\n    height = source.height\n    pixels = bytes(source.data)\n    if width <= 0 or height <= 0:\n        raise ValueError(\"TIFF encoder requires positive dimensions.\")\n\n    if compression == \"packbits\":\n        strip_data = _pack_packbits(pixels)\n        compression_code = _COMPRESSION_PACKBITS\n    elif compression in {\"none\", \"uncompressed\"}:\n        strip_data = pixels\n        compression_code = _COMPRESSION_NONE\n    else:\n        raise ValueError(f\"Unsupported TIFF compression: {compression}\")\n\n    ifd_offset = 8\n    entry_count = 8\n    ifd_size = 2 + entry_count * 12 + 4\n    bits_offset = ifd_offset + ifd_size\n    strip_offset = bits_offset + 8\n    bits_per_sample = struct.pack(\"<HHH\", 8, 8, 8)\n\n    ifd = bytearray()\n    ifd.extend(_write_ifd_entry(256, 3, 1, width))\n    ifd.extend(_write_ifd_entry(257, 3, 1, height))\n    ifd.extend(_write_ifd_entry(258, 3, 3, bits_offset))\n    ifd.extend(_write_ifd_entry(259, 3, 1, compression_code))\n    ifd.extend(_write_ifd_entry(262, 3, 1, _PHOTOMETRIC_RGB))\n    ifd.extend(_\n... [truncated]",
