    "language": "python",
    "content": "server/src/image_tool/tiff/encode.py :: _pack_packbits\ndef _pack_packbits(source: bytes) -> bytes:\n    output = bytearray()\n    index = 0\n    while index < len(source):\n        run_start = index\n        while index + 1 < len(source) and source[index] == source[index + 1]:\n            index += 1\n        literal_run = index - run_start\n        if literal_run >= 2:\n            while literal_run > 0:\n                chunk = min(128, literal_run)\n                output.append(chunk - 1)\n                output.extend(source[run_start : run_start + chunk])\n                run_start += chunk\n                literal_run -= chunk\n            index = run_start\n            continue\n\n        literal_start = index\n        while index < len(source):\n            if index + 2 < len(source) and source[index] == source[index + 1] == source[index + 2]:\n                break\n            if index - literal_start >= 128:\n                break\n            index += 1\n        literal_len = index - literal_start\n        if literal_len == 0:\n            index += 1\n            literal_len = 1\n        output.append(literal_len - 1)\n        output.extend(source[literal_start : literal_start + literal_len])\n    return bytes(output)",
