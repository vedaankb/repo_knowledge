    "content": "server/tests/test_api_webp.py :: test_convert_png_to_webp\ndef test_convert_png_to_webp(client: TestClient) -> None:\n    payload = png_bytes(solid_raster(20, 20, 100, 50, 50))\n    response = client.post(\n        \"/convert\",\n        files={\"image\": (\"input.png\", payload, \"image/png\")},\n        data={\"format\": \"webp\", \"max_mb\": \"1\"},\n    )\n    assert response.status_code == 200\n    assert response.headers[\"content-type\"] == \"image/webp\"\n    assert response.content[8:12] == b\"WEBP\"",
