    "language": "python",
    "content": "server/tests/test_api_analyze.py :: test_analyze_endpoint\ndef test_analyze_endpoint(client: TestClient) -> None:\n    payload = png_bytes(solid_raster(10, 10, 100, 50, 25))\n    response = client.post(\n        \"/analyze\",\n        files={\"image\": (\"test.png\", payload, \"image/png\")},\n    )\n    assert response.status_code == 200\n    body = response.json()\n    assert body[\"format\"] == \"png\"\n    assert body[\"width\"] == 10\n    assert \"summary\" in body\n    assert \"dominant_colors\" in body\n    assert \"average_rgb\" in body\n    assert \"stats\" in body\n    assert body[\"stats\"][\"exposure\"] in {\n        \"underexposed\",\n        \"overexposed\",\n        \"dark\",\n        \"bright\",\n        \"balanced\",\n    }\n    assert \"sharpness\" in body[\"stats\"]\n    assert \"histogram\" in body[\"stats\"]",
