    "content": "server/tests/test_corpus_pipeline.py :: test_validate_accepts_corpus_encodings\ndef test_validate_accepts_corpus_encodings(sample_name: str):\n    sample = next(item for item in build_default_corpus() if item.name == sample_name)\n    for extension, encoder in ENCODERS.items():\n        payload = encoder(sample.raster)\n        report = validate_image(payload, f\"{sample_name}.{extension}\")\n        assert report[\"valid\"] is True\n        assert report[\"decodable\"] is True\n        assert report[\"stats\"][\"sharpness\"] >= 0",
