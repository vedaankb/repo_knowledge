[
  {
    "file": "server/tests/test_corpus_pipeline.py",
    "symbol": "test_each_corpus_sample_analyzes_after_encode",
    "kind": "function_definition",
    "language": "python",
    "content": "server/tests/test_corpus_pipeline.py :: test_each_corpus_sample_analyzes_after_encode\ndef test_each_corpus_sample_analyzes_after_encode(encoder_name: str):\n    encoder = ENCODERS[encoder_name]\n    for sample in build_default_corpus(width=14, height=12):\n        payload = encoder(sample.raster)\n        report = analyze_image(payload, f\"{sample.name}.{encoder_name}\")\n        assert report[\"width\"] >= sample.raster.width\n        assert report[\"height\"] >= sample.raster.height\n        assert report[\"stats\"] is not None\n        assert report[\"stats\"][\"dimensions\"][\"width\"] == report[\"width\"]",
    "content_hash": "sha256:f9ce22eba5b518ea31654dcbe6f430971ebf95c6a3a835f9033d99f58f7d80d8",
