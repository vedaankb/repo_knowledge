[
  {
    "file": "server/src/image_tool/raster.py",
    "symbol": "Raster",
    "kind": "class_definition",
    "language": "python",
    "content": "server/src/image_tool/raster.py :: Raster\nclass Raster:\n    width: int\n    height: int\n    channels: int\n    data: bytearray\n\n    def clone(self) -> \"Raster\":\n        return Raster(self.width, self.height, self.channels, bytearray(self.data))\n\n    def to_rgb(self) -> \"Raster\":\n        if self.channels == 3:\n            return self.clone()\n        if self.channels != 4:\n            raise ValueError(f\"Unsupported channel count: {self.channels}\")\n\n        rgb = bytearray(self.width * self.height * 3)\n        for index in range(self.width * self.height):\n            alpha = self.data[index * 4 + 3] / 255.0\n            inverse = 1.0 - alpha\n            for channel in range(3):\n                foreground = self.data[index * 4 + channel]\n                rgb[index * 3 + channel] = int(foreground * alpha + 255 * inverse)\n        return Raster(self.width, self.height, 3, rgb)",
    "content_hash": "sha256:4845cac2c5518fbc8ef4d9dd3f75e132d740e6e7597b9b27ee9798eadb3513be",
