    "content": "server/tests/test_cli_validate.py :: test_cli_validate_json\ndef test_cli_validate_json(tmp_path: Path) -> None:\n    source = tmp_path / \"photo.png\"\n    source.write_bytes(png_bytes(solid_raster(10, 10, 100, 50, 50)))\n    import contextlib\n    import io\n\n    buffer = io.StringIO()\n    with contextlib.redirect_stdout(buffer):\n        code = main([\"validate\", str(source), \"--json\"])\n    assert code == 0\n    payload = json.loads(buffer.getvalue())\n    assert payload[\"valid\"] is True",
