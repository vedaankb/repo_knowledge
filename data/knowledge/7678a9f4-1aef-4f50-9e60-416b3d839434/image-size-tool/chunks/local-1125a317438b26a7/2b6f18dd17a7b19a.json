    "content": "server/tests/test_api_compare.py :: test_compare_endpoint\ndef test_compare_endpoint(client: TestClient) -> None:\n    left = png_bytes(solid_raster(16, 16, 200, 50, 50))\n    right = png_bytes(solid_raster(16, 16, 200, 50, 50))\n    response = client.post(\n        \"/compare\",\n        files={\n            \"left\": (\"left.png\", left, \"image/png\"),\n            \"right\": (\"right.png\", right, \"image/png\"),\n        },\n    )\n    assert response.status_code == 200\n    payload = response.json()\n    assert payload[\"identical_pixels\"] is True\n    assert payload[\"ssim\"] == 1.0",
