    "content": "server/tests/test_color.py :: test_rgb_ycbcr_roundtrip_neutral_gray\ndef test_rgb_ycbcr_roundtrip_neutral_gray() -> None:\n    for value in (0, 64, 128, 192, 255):\n        y, cb, cr = rgb_to_ycbcr(value, value, value)\n        red, green, blue = ycbcr_to_rgb(y, cb, cr)\n        assert abs(red - value) <= 2\n        assert abs(green - value) <= 2\n        assert abs(blue - value) <= 2",
