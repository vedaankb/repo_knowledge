    "file": "server/src/image_tool/exif/reader.py",
    "symbol": "extract_jpeg_exif_segment",
    "kind": "function_definition",
    "language": "python",
    "content": "server/src/image_tool/exif/reader.py :: extract_jpeg_exif_segment\ndef extract_jpeg_exif_segment(data: bytes) -> bytes | None:\n    if not data.startswith(b\"\\xFF\\xD8\"):\n        return None\n\n    index = 2\n    while index + 4 < len(data):\n        if data[index] != 0xFF:\n            index += 1\n            continue\n        marker = data[index + 1]\n        if marker == 0xD9:\n            break\n        if marker in (0xD8,):\n            index += 2\n            continue\n        length = struct.unpack_from(\">H\", data, index + 2)[0]\n        segment_end = index + 2 + length\n        if segment_end > len(data):\n            break\n        payload = data[index + 4 : segment_end]\n        if marker == 0xE1 and payload.startswith(b\"Exif\\x00\\x00\"):\n            return payload\n        index = segment_end\n    return None",
