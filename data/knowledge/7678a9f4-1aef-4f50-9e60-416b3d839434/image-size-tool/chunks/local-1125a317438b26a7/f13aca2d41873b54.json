    "content": "server/tests/test_analyze.py :: test_analyze_jpeg_with_exif\ndef test_analyze_jpeg_with_exif() -> None:\n    base = encode_jpeg(solid_raster(16, 12, 200, 100, 50))\n    payload = _inject_app1(base, _build_exif_app1(orientation=3, make=\"Image01\"))\n    report = analyze_image(payload, \"photo.jpg\")\n    assert report[\"format\"] == \"jpeg\"\n    exif = report[\"exif\"]\n    assert exif[\"present\"] is True\n    assert exif[\"orientation\"] == 3\n    assert exif[\"tags\"][\"Make\"] == \"Image01\"\n    assert report[\"jpeg_metadata_present\"] is True\n    assert \"GPS\" not in report[\"summary\"] or report[\"exif\"][\"has_gps\"] is False",
