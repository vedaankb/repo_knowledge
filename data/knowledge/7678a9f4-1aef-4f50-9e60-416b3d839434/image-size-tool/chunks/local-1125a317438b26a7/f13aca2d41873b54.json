    "content": "server/tests/test_analyze.py :: test_analyze_png_image\ndef test_analyze_png_image() -> None:\n    payload = png_bytes(gradient_raster(24, 16))\n    report = analyze_image(payload, \"sample.png\")\n    assert report[\"format\"] == \"png\"\n    assert report[\"width\"] == 24\n    assert report[\"height\"] == 16\n    assert report[\"channels\"] == 3\n    assert report[\"has_alpha\"] is False\n    assert report[\"aspect_ratio\"] == 1.5\n    assert len(report[\"histogram_luminance\"]) == 64\n    assert len(report[\"dominant_colors\"]) >= 1\n    assert \"summary\" in report\n    assert report[\"average_luminance\"] >= 0",
