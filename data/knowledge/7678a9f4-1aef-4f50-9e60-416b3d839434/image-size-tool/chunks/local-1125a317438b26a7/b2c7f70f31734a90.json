    "content": "server/src/image_tool/edit_options.py :: EditOptions\nclass EditOptions:\n    crop_x: int | None = None\n    crop_y: int | None = None\n    crop_width: int | None = None\n    crop_height: int | None = None\n    resize_width: int | None = None\n    resize_height: int | None = None\n    filter_name: str = \"none\"\n    post_filter: str = \"none\"\n\n    @classmethod\n    def from_form(\n        cls,\n        crop_x: str | int | float | None = None,\n        crop_y: str | int | float | None = None,\n        crop_w: str | int | float | None = None,\n        crop_h: str | int | float | None = None,\n        resize_w: str | int | float | None = None,\n        resize_h: str | int | float | None = None,\n        filter: str | None = \"none\",\n        post_filter: str | None = \"none\",\n    ) -> \"EditOptions\":\n        return cls(\n            crop_x=_optional_coord(crop_x),\n            crop_y=_optional_coord(crop_y),\n            crop_width=_optional_positive_int(crop_w),\n            crop_height=_optional_positive_int(crop_h),\n            resize_width=_optional_positive_int(resize_w),\n            resize_height=_optional_positive_int(resize_h),\n            filter_name=(filter or \"none\").strip().lower(),\n            post_filter=(post_filter or \"none\").strip().lower(),\n     \n... [truncated]",
