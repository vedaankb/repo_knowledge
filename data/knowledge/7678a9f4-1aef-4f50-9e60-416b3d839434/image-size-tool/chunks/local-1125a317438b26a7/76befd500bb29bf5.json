    "kind": "function_definition",
    "language": "python",
    "content": "server/src/image_tool/jpeg/decode_pillow.py :: decode_jpeg_pillow\ndef decode_jpeg_pillow(data: bytes) -> Raster:\n    try:\n        from PIL import Image, ImageFile\n    except ImportError as error:\n        raise ValueError(\n            \"JPEG decoding failed and Pillow is not installed. \"\n            \"Install pillow in the server environment.\"\n        ) from error\n\n    ImageFile.LOAD_TRUNCATED_IMAGES = True\n    try:\n        with Image.open(io.BytesIO(data)) as image:\n            image.load()\n            rgb = image.convert(\"RGB\")\n    except OSError as error:\n        raise ValueError(f\"Could not decode JPEG image: {error}\") from error\n\n    width, height = rgb.size\n    return Raster(width, height, 3, bytearray(rgb.tobytes()))",
