[
  {
    "file": "server/src/image_tool/jpeg/quant.py",
    "symbol": "scale_quantization_table",
    "kind": "function_definition",
    "language": "python",
    "content": "server/src/image_tool/jpeg/quant.py :: scale_quantization_table\ndef scale_quantization_table(base_table: list[int], quality: int) -> list[int]:\n    quality = max(1, min(100, quality))\n    if quality < 50:\n        scale = 5000 / quality\n    else:\n        scale = 200 - (2 * quality)\n\n    scaled = []\n    for value in base_table:\n        scaled_value = int((value * scale + 50) / 100)\n        scaled.append(max(1, min(255, scaled_value)))\n    return scaled",
    "content_hash": "sha256:2db079b53d6398026b40dadceec457fdde0fb521454f862fc691ba16c432445e",
