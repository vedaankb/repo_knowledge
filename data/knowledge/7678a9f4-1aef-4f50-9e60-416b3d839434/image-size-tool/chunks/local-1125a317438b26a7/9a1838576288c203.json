    "content": "server/tests/test_format_matrix.py :: test_corpus_sample_converts_across_formats\ndef test_corpus_sample_converts_across_formats(input_name: str, output_name: str):\n    sample = build_default_corpus(width=20, height=16)[0]\n    builder = INPUT_BUILDERS[input_name]\n    source = builder(sample.raster)\n    raster = load_raster_from_bytes(source, f\"sample.{input_name}\")\n    output_format = OUTPUT_FORMATS[output_name]\n    result = convert_raster(raster, output_format, max_mb=1)\n    assert result\n    decoded = decode_image(result, f\"out.{output_format.extension}\")\n    assert decoded.width > 0\n    assert decoded.height > 0",
