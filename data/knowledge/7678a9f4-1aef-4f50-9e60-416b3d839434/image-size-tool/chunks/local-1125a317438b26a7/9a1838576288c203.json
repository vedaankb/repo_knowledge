    "content": "server/tests/test_format_matrix.py :: test_tiff_input_to_jpeg_and_webp\ndef test_tiff_input_to_jpeg_and_webp():\n    sample = build_default_corpus(width=22, height=18)[3]\n    source = tiff_bytes(sample.raster)\n    raster = load_raster_from_bytes(source, \"input.tiff\")\n    for output_name in (\"jpeg\", \"webp\"):\n        output_format = OUTPUT_FORMATS[output_name]\n        result = convert_raster(raster, output_format, max_mb=1)\n        assert len(result) > 100\n        decode_image(result, f\"converted.{output_format.extension}\")",
