    "content": "server/tests/test_api_validate.py :: test_validate_endpoint_accepts_png\ndef test_validate_endpoint_accepts_png(client: TestClient) -> None:\n    payload = png_bytes(solid_raster(10, 10, 200, 50, 50))\n    response = client.post(\n        \"/validate\",\n        files={\"image\": (\"input.png\", payload, \"image/png\")},\n    )\n    assert response.status_code == 200\n    body = response.json()\n    assert body[\"valid\"] is True\n    assert body[\"format\"] == \"png\"",
