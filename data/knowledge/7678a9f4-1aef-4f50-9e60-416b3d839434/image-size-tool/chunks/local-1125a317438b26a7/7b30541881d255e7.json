    "content": "server/src/image_tool/resample.py :: resize_rgb\ndef resize_rgb(raster: Raster, target_width: int, target_height: int) -> Raster:\n    if raster.channels != 3:\n        raster = raster.to_rgb()\n\n    if target_width <= 0 or target_height <= 0:\n        raise ValueError(\"Target dimensions must be positive.\")\n\n    if target_width == raster.width and target_height == raster.height:\n        return raster.clone()\n\n    output = bytearray(target_width * target_height * 3)\n    x_ratio = raster.width / target_width\n    y_ratio = raster.height / target_height\n\n    for y in range(target_height):\n        source_y = (y + 0.5) * y_ratio - 0.5\n        y0 = max(0, min(raster.height - 1, int(source_y)))\n        y1 = max(0, min(raster.height - 1, y0 + 1))\n        y_weight = source_y - y0\n\n        for x in range(target_width):\n            source_x = (x + 0.5) * x_ratio - 0.5\n            x0 = max(0, min(raster.width - 1, int(source_x)))\n            x1 = max(0, min(raster.width - 1, x0 + 1))\n            x_weight = source_x - x0\n\n            for channel in range(3):\n                top_left = raster.data[(y0 * raster.width + x0) * 3 + channel]\n                top_right = raster.data[(y0 * raster.width + x1) * 3 + channel]\n                bottom_left = ras\n... [truncated]",
