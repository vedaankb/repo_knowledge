    "language": "python",
    "content": "server/src/image_tool/resample.py :: fit_inside\ndef fit_inside(raster: Raster, max_longest: int) -> Raster:\n    longest = max(raster.width, raster.height)\n    if longest <= max_longest:\n        return raster.clone()\n    scale = max_longest / longest\n    target_width = max(1, int(raster.width * scale))\n    target_height = max(1, int(raster.height * scale))\n    return resize_rgb(raster, target_width, target_height)",
