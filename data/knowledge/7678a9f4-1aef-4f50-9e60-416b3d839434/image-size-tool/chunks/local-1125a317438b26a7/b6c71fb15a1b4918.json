    "content": "server/src/image_tool/gif/encode.py :: encode_gif\ndef encode_gif(raster: Raster, max_colors: int = 256) -> bytes:\n    if raster.channels != 3:\n        raster = raster.to_rgb()\n\n    palette = median_cut_palette(raster.data, raster.width, raster.height, max_colors=max_colors)\n    palette, table_size = pad_palette(palette)\n    indices = map_to_palette(raster.data, raster.width, raster.height, palette)\n\n    min_code_size = _lzw_min_code_size(table_size)\n    compressed = encode_lzw(indices, table_size)\n    lzw_data = bytes([min_code_size]) + pack_lzw_blocks(compressed)\n\n    packed = _global_color_table_packed(table_size)\n    output = bytearray(b\"GIF89a\")\n    output.extend(\n        struct.pack(\n            \"<HHBBB\",\n            raster.width,\n            raster.height,\n            packed,\n            0,\n            0,\n        )\n    )\n    output.extend(_palette_bytes(palette))\n\n    # Graphic control extension: no transparency, normal disposal.\n    output.extend(b\"\\x21\\xF9\\x04\\x00\\x00\\x00\\x00\\x00\")\n\n    output.append(0x2C)\n    output.extend(\n        struct.pack(\n            \"<HHHHB\",\n            0,\n            0,\n            raster.width,\n            raster.height,\n            0x00,\n        )\n    )\n    output.extend(lzw_data)\n    output.ap\n... [truncated]",
