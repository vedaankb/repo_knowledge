    "content": "server/src/image_tool/jpeg/dct.py :: forward_dct\ndef forward_dct(block: list[list[float]]) -> list[list[float]]:\n    output = [[0.0 for _ in range(BLOCK_SIZE)] for _ in range(BLOCK_SIZE)]\n    for row in range(BLOCK_SIZE):\n        for col in range(BLOCK_SIZE):\n            total = 0.0\n            for source_row in range(BLOCK_SIZE):\n                for source_col in range(BLOCK_SIZE):\n                    total += (\n                        block[source_row][source_col]\n                        * math.cos(((2 * source_row) + 1) * row * math.pi / 16.0)\n                        * math.cos(((2 * source_col) + 1) * col * math.pi / 16.0)\n                    )\n            output[row][col] = 0.25 * DCT_SCALE[row][col] * total\n    return output",
